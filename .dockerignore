# Keep the Docker build context lean.
# Rules kept intentionally simple: no negations (`!pattern`) — they can trigger
# BuildKit "not found" edge cases on directory COPY with composite caches.

# Dependency dirs / build output
**/node_modules
**/.next
**/dist
**/.turbo
**/coverage
**/.vercel
**/.railway
**/.fly

# TS incremental + composite leak
**/*.tsbuildinfo
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# Env files — NEVER baked into images
.env
.env.local
.env.*.local

# Git / IDE / OS noise
.git
.github
.gitignore
.dockerignore
.idea
.vscode
.DS_Store
*.log
tmp

# Supabase CLI cache
supabase/.temp
supabase/.branches

# Docs & scripts not needed at runtime
docs
scripts
