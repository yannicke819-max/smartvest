{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "src",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "composite": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "references": [
    { "path": "../../packages/shared-types" },
    { "path": "../../packages/domain" },
    { "path": "../../packages/cost-engine" },
    { "path": "../../packages/audit" },
    { "path": "../../packages/brokers" },
    { "path": "../../packages/portfolio-engine" },
    { "path": "../../packages/ai-analyst" },
    { "path": "../../packages/backtest" },
    { "path": "../../packages/strategy-optimizer" },
    { "path": "../../packages/monte-carlo" }
  ],
  "include": ["src/**/*"],
  "ts-node": {
    "transpileOnly": true,
    "require": ["tsconfig-paths/register"],
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "Node"
    }
  }
}
