{
  "name": "@smartvest/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -b",
    "start": "sh -c '([ -f ../../scripts/apply-migrations.mjs ] && node ../../scripts/apply-migrations.mjs); node dist/main.js'",
    "start:dev": "ts-node -r tsconfig-paths/register --transpile-only src/main.ts",
    "start:debug": "node --inspect -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "migrate": "node ../../scripts/apply-migrations.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/schedule": "^4.1.1",
    "@smartvest/ai-analyst": "*",
    "@smartvest/audit": "*",
    "@smartvest/brokers": "*",
    "@smartvest/cost-engine": "*",
    "@smartvest/domain": "*",
    "@smartvest/portfolio-engine": "*",
    "@smartvest/shared-types": "*",
    "@supabase/supabase-js": "^2.45.4",
    "@types/ws": "^8.18.1",
    "decimal.js": "^10.4.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.20.0",
    "yahoo-finance2": "^2.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.14.15",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@smartvest/shared-types$": "<rootDir>/../../../packages/shared-types/src/index.ts",
      "^@smartvest/domain$": "<rootDir>/../../../packages/domain/src/index.ts",
      "^@smartvest/portfolio-engine$": "<rootDir>/../../../packages/portfolio-engine/src/index.ts",
      "^@smartvest/cost-engine$": "<rootDir>/../../../packages/cost-engine/src/index.ts",
      "^@smartvest/audit$": "<rootDir>/../../../packages/audit/src/index.ts",
      "^@smartvest/brokers$": "<rootDir>/../../../packages/brokers/src/index.ts",
      "^@smartvest/ai-analyst$": "<rootDir>/../../../packages/ai-analyst/src/index.ts"
    }
  }
}
