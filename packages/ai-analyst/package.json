{
  "name": "@smartvest/ai-analyst",
  "version": "0.1.0",
  "private": true,
  "description": "Lisa — multi-asset agnostic AI analyst. Cross-asset thesis generation, anti-consensus filter, historical analog matching, risk-constrained allocation proposals. Simulation-first.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "backtest:rebound": "node dist/cli/backtest-rebound.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@smartvest/domain": "*",
    "@smartvest/shared-types": "*",
    "@supabase/supabase-js": "^2.45.4",
    "decimal.js": "^10.4.3",
    "json5": "^2.2.3",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@google/genai": "*",
    "@mistralai/mistralai": "*",
    "openai": "*"
  },
  "peerDependenciesMeta": {
    "@google/genai": { "optional": true },
    "@mistralai/mistralai": { "optional": true },
    "openai": { "optional": true }
  },
  "devDependencies": {
    "@google/genai": "^0.7.0",
    "@mistralai/mistralai": "^1.3.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.14.15",
    "jest": "^29.7.0",
    "openai": "^4.65.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
