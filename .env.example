# SmartVest — variables d'environnement (copier vers .env.local et remplir)

# ── Feature flags produit ──────────────────────────────────────────────────────
# PERSONAL_MODE: usage strictement personnel (aucun disclaimer grand public requis).
# SAFE_PUBLIC_MODE: bêta publique restreinte, wording neutre, simulations only.
# REGULATED_MODE: fonctionnalités nécessitant agrément (RTO/CIF) — désactivé par défaut.
NEXT_PUBLIC_FEATURE_PERSONAL_MODE=true
NEXT_PUBLIC_FEATURE_SAFE_PUBLIC_MODE=false
NEXT_PUBLIC_FEATURE_REGULATED_MODE=false

# ── Feature flags de délégation ───────────────────────────────────────────────
# MANUAL_EXPLICIT : analyse / simulation uniquement, aucune action autonome (défaut).
# HYBRID_SUGGESTIVE : suggestions avec validation explicite utilisateur requise.
# AUTONOMOUS_GUARDED : exécution dans mandat — jamais actif sans AutonomyMandate valide.
# Accepte aussi les alias FEATURE_MANUAL_MODE_ENABLED / FEATURE_HYBRID_MODE_ENABLED / FEATURE_AUTONOMOUS_MODE_ENABLED
FEATURE_DELEGATION_MANUAL_EXPLICIT=true
FEATURE_DELEGATION_HYBRID_SUGGESTIVE=false
FEATURE_DELEGATION_AUTONOMOUS_GUARDED=false

# Kill-switch global — passe à true pour suspendre TOUTE exécution autonome immédiatement.
FEATURE_AUTONOMY_KILL_SWITCH=false

# ── Feature flags broker ──────────────────────────────────────────────────────
# READ_ONLY_BROKER_SYNC: import positions/transactions depuis broker API (lecture seule).
# BROKER_EXECUTION: soumission réelle d'ordres — nécessite mandat valide + AUTONOMOUS_GUARDED.
FEATURE_READ_ONLY_BROKER_SYNC_ENABLED=false
FEATURE_BROKER_EXECUTION_ENABLED=false

# ── Feature flags hyper-trading (mode personnel très actif) ──────────────────
# Mode opt-in strict. Aucun flag activé par défaut. La granularité permet :
#   MODE_ENABLED      : expose le concept côté API (pas d'effet sans les autres).
#   UI_ENABLED        : rend les écrans de configuration visibles (front).
#   RUNTIME_ENABLED   : moteur d'évaluation des intents actif (server).
#   EXECUTION_ENABLED : autoriserait l'exécution réelle, mais requiert EN PLUS
#                       un mandat valide + AUTONOMOUS_GUARDED + BROKER_EXECUTION_ENABLED.
# Activer EXECUTION_ENABLED ne suffit jamais seul à exécuter ; toutes les
# autres conditions de garde-fou doivent être réunies.
FEATURE_HYPER_TRADING_MODE_ENABLED=false
FEATURE_HYPER_TRADING_UI_ENABLED=false
FEATURE_HYPER_TRADING_RUNTIME_ENABLED=false
FEATURE_HYPER_TRADING_EXECUTION_ENABLED=false
NEXT_PUBLIC_FEATURE_HYPER_TRADING_UI_ENABLED=false

# ── Mode sniper (surcouche personnelle, déverrouillage par code) ─────────────
# Surcouche simple, opt-in, TTL borné. Ne contourne ni mandat, ni kill-switch,
# ni checkMandatePermission(). Le flag seul ne suffit pas — il faut aussi que
# SNIPER_MODE_UNLOCK_CODE soit défini côté serveur pour que /sniper/unlock marche.
FEATURE_SNIPER_MODE_ENABLED=false
FEATURE_SNIPER_MODE_UI_ENABLED=false
NEXT_PUBLIC_FEATURE_SNIPER_MODE_UI_ENABLED=false
# Code local de déverrouillage (serveur uniquement, jamais exposé au front).
# Laisser vide désactive totalement /sniper/unlock.
SNIPER_MODE_UNLOCK_CODE=
# TTL par défaut d'une session sniper (minutes, 1–240). Défaut : 15.
SNIPER_MODE_TTL_MINUTES=15

# ── Broker connections (connexions brokers personnelles) ─────────────────────
# Master gate pour /brokers — on par défaut (lecture / config).
FEATURE_BROKER_CONNECTIONS_ENABLED=true
# Sync lecture seule — on par défaut.
FEATURE_BROKER_SYNC_READ_ONLY_ENABLED=true
# Adapters live (HTTP réel). Tous off par défaut — à activer un par un
# après vérification manuelle des credentials.
FEATURE_BROKER_ADAPTER_IB_ENABLED=false
FEATURE_BROKER_ADAPTER_SAXO_ENABLED=false
FEATURE_BROKER_ADAPTER_DEGIRO_ENABLED=false
FEATURE_BROKER_ADAPTER_TRADING212_ENABLED=false

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Données de marché ─────────────────────────────────────────────────────────
# EOD Historical Data — https://eodhd.com — clé API requise pour cotations réelles.
# Valeur "demo" active les données démo limitées (utile en dev).
EODHD_API_KEY=demo

# ── Sentry (optionnel) ────────────────────────────────────────────────────────
SENTRY_DSN=

# ── ADR-001 (30/04/2026) LLM router — Scanner Gainers ──────────────────────
# Active la chain Gemini Flash-Lite (primary) → Claude Opus 4.7 (fallback ultime)
# pour les appels LLM du scanner (analyse signal / ranking / thesis pre-filter).
# Bench P16 : Gemini Flash-Lite gagnant — composite 0.66, $0.00011/prompt
# (-99.3% vs Claude Sonnet 4.5 sur la tâche scanner).
# Cf. docs/decision_records/ADR-001-llm-architecture.md
SCANNER_LLM_ROUTER_ENABLED=true

# Clés API. Au moins GEMINI_API_KEY doit être présente quand le flag est ON,
# sinon le router se désactive automatiquement et le path Claude legacy reste utilisé.
# - GEMINI_API_KEY    : Google AI (gemini-2.5-flash-lite, region europe-west1)
# - ANTHROPIC_API_KEY : Anthropic (claude-opus-4-7, fallback ultime + thesis_generation)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ─── P20 (30/04/2026) — Fees-aware target guard ─────────────────────────────
# Buffer multiplicatif appliqué aux fees round-trip pour décider d'ouvrir une
# position. expected_gain_at_TP doit être ≥ FEES_AWARE_BUFFER × round_trip_fees.
# Range autorisé : [1.0, 5.0]. Default si non set : 2.0.
#   1.0 = break-even strict (pas de marge slippage)
#   2.0 = baseline conservateur (recommandé)
#   3.0 = très défensif (peut bloquer trop d'ouvertures sur petits TP)
# Justification 2.0 : closed_target SLV +0.171 % a livré net -$0.92 en J-7.
FEES_AWARE_BUFFER=2.0
