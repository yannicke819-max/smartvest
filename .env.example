# SmartVest — variables d'environnement (copier vers .env.local et remplir)

# ── Feature flags produit ──────────────────────────────────────────────────────
# PERSONAL_MODE: usage strictement personnel (aucun disclaimer grand public requis).
# SAFE_PUBLIC_MODE: bêta publique restreinte, wording neutre, simulations only.
# REGULATED_MODE: fonctionnalités nécessitant agrément (RTO/CIF) — désactivé par défaut.
NEXT_PUBLIC_FEATURE_PERSONAL_MODE=true
NEXT_PUBLIC_FEATURE_SAFE_PUBLIC_MODE=false
NEXT_PUBLIC_FEATURE_REGULATED_MODE=false

# ── Feature flags de délégation ───────────────────────────────────────────────
# MANUAL_EXPLICIT : analyse / simulation uniquement, aucune action autonome (défaut).
# HYBRID_SUGGESTIVE : suggestions avec validation explicite utilisateur requise.
# AUTONOMOUS_GUARDED : exécution dans mandat — jamais actif sans AutonomyMandate valide.
# Accepte aussi les alias FEATURE_MANUAL_MODE_ENABLED / FEATURE_HYBRID_MODE_ENABLED / FEATURE_AUTONOMOUS_MODE_ENABLED
FEATURE_DELEGATION_MANUAL_EXPLICIT=true
FEATURE_DELEGATION_HYBRID_SUGGESTIVE=false
FEATURE_DELEGATION_AUTONOMOUS_GUARDED=false

# Kill-switch global — passe à true pour suspendre TOUTE exécution autonome immédiatement.
FEATURE_AUTONOMY_KILL_SWITCH=false

# ── Feature flags broker ──────────────────────────────────────────────────────
# READ_ONLY_BROKER_SYNC: import positions/transactions depuis broker API (lecture seule).
# BROKER_EXECUTION: soumission réelle d'ordres — nécessite mandat valide + AUTONOMOUS_GUARDED.
FEATURE_READ_ONLY_BROKER_SYNC_ENABLED=false
FEATURE_BROKER_EXECUTION_ENABLED=false

# ── Feature flags hyper-trading (mode personnel très actif) ──────────────────
# Mode opt-in strict. Aucun flag activé par défaut. La granularité permet :
#   MODE_ENABLED      : expose le concept côté API (pas d'effet sans les autres).
#   UI_ENABLED        : rend les écrans de configuration visibles (front).
#   RUNTIME_ENABLED   : moteur d'évaluation des intents actif (server).
#   EXECUTION_ENABLED : autoriserait l'exécution réelle, mais requiert EN PLUS
#                       un mandat valide + AUTONOMOUS_GUARDED + BROKER_EXECUTION_ENABLED.
# Activer EXECUTION_ENABLED ne suffit jamais seul à exécuter ; toutes les
# autres conditions de garde-fou doivent être réunies.
FEATURE_HYPER_TRADING_MODE_ENABLED=false
FEATURE_HYPER_TRADING_UI_ENABLED=false
FEATURE_HYPER_TRADING_RUNTIME_ENABLED=false
FEATURE_HYPER_TRADING_EXECUTION_ENABLED=false
NEXT_PUBLIC_FEATURE_HYPER_TRADING_UI_ENABLED=false

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Données de marché ─────────────────────────────────────────────────────────
# EOD Historical Data — https://eodhd.com — clé API requise pour cotations réelles.
# Valeur "demo" active les données démo limitées (utile en dev).
EODHD_API_KEY=demo

# ── Sentry (optionnel) ────────────────────────────────────────────────────────
SENTRY_DSN=
