{
  "name": "smartvest",
  "private": true,
  "version": "0.1.0",
  "description": "SmartVest — assistant personnel d'investissement (Phase 1).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "eslint \"{apps,packages}/**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "tsc -b",
    "web:dev": "npm run dev -w @smartvest/web",
    "api:dev": "npm run start:dev -w @smartvest/api",
    "bench:scanner-eu": "tsx --experimental-vm-modules bench/scanner-llm/main.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
